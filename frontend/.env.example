# Copy this file to `.env` and fill the values from your Microsoft Entra
# App registration (Overview page). Client id is not a secret.
#   Application (client) ID -> VITE_AAD_CLIENT_ID
#   Directory (tenant) ID   -> VITE_AAD_TENANT_ID   (single-tenant: use the GUID, not "common")
VITE_AAD_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_AAD_TENANT_ID=00000000-0000-0000-0000-000000000000
